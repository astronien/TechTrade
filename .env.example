# Supabase Database Configuration
POSTGRES_URL_NON_POOLING=postgres://postgres.xxx:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# LINE Bot Configuration (Optional)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Application Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-in-production

# Turso Sync Configuration
# Used by auto_daily_export.py and /api/v2/* endpoints to store and verify Eve trade snapshots.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# API / Cron Security
# API_KEY protects /api/v2/* when not accessed through an authenticated web session.
# CRON_SECRET protects /api/admin/auto-export-cron and scheduled jobs.
API_KEY=change-this-api-key
CRON_SECRET=change-this-cron-secret
